params {
    // Input/Output
    fastq_dir = "/datos/migccl/exposoma_fusion/fastqs"
    outdir = "${launchDir}/results"
    
    // Sample selection (default to all)
    // Pass --sample_id "Sample_123" to run specific sample
    // or --sample_pattern "*_R{1,2}_*.fastq.gz" to match files
    sample_id = null 
    
    // Optional override for FASTQ glob (takes precedence over sample_id)
    // Example:
    //   --fastq_glob '/datos/migccl/exposoma_fusion/fastqs/218-MO-19-563507503/*_R{1,2}_*.fastq.gz'
    fastq_glob = null

    // Fusion caller: "arriba", "starfusion", or "fusioncatcher"
    method = "arriba"

    // Optional rRNA filtering + QC
    filter_rrna = false
    rrna_qc = true
    // Skip FASTQC and MULTIQC steps
    skip_fastqc = false
    rrna_ref = null
    rrna_k = 31
    rrna_hdist = 1
    rrna_threads = 10
    rrna_ram = "60.GB"

    // Common fusion annotations
    annotate_common_fusions = true
    literature_email = null
    
    // Resources
    threads = 19
    star_ram = "100.GB"
    
    // References (Defaults based on notebook, can be overridden)
    ref_dir = "${params.fastq_dir}/arriba_refs"
    genome_fasta = "${params.ref_dir}/GRCh38.primary_assembly.genome.fa"
    gtf = "${params.ref_dir}/gencode.v41.basic.annotation.gtf"
    star_index = "${params.ref_dir}/star_grch38_primary"
    
    // Arriba databases
    arriba_dir = "${params.ref_dir}/arriba_v2.5.1"
    blacklist = "${params.arriba_dir}/database/blacklist_hg38_GRCh38_v2.5.1.tsv.gz"
    known_fusions = "${params.arriba_dir}/database/known_fusions_hg38_GRCh38_v2.5.1.tsv.gz"
    protein_domains = "${params.arriba_dir}/database/protein_domains_hg38_GRCh38_v2.5.1.gff3"
    cytobands = "${params.arriba_dir}/database/cytobands_hg38_GRCh38_v2.5.1.tsv"

    // STAR-Fusion (CTAT genome lib)
    starfusion_genome_lib = "${params.ref_dir}/starfusion_genome_lib"
    // Add STAR-Fusion args here if you want extra sensitivity (e.g., FusionInspector)
    // starfusion_extra_args = "--FusionInspector validate"
    starfusion_extra_args = ""
    starfusion_ram = params.star_ram

    // FusionCatcher
    fusioncatcher_dir = "${params.ref_dir}/fusioncatcher_data"
    fusioncatcher_threads = 10
    fusioncatcher_ram = "60.GB"
}

process {
    executor = 'local'
    withName: 'STAR_ARRIBA' {
        cpus = params.threads
        memory = params.star_ram
    }
    withName: 'FASTQC' {
        cpus = 5
        memory = '10.GB'
        maxForks = 2
    }
    withName: 'RRNA_FILTER' {
        cpus = params.rrna_threads
        memory = params.rrna_ram
    }
    withName: 'RRNA_QC' {
        cpus = 1
        memory = '2.GB'
    }
    withName: 'STARFUSION' {
        cpus = params.threads
        memory = params.starfusion_ram
    }
    withName: 'FUSIONCATCHER' {
        cpus = params.fusioncatcher_threads
        memory = params.fusioncatcher_ram
    }
}

profiles {
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/environment.yml"
    }
}
